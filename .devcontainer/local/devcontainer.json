{
    "name": "WonderTrader Development",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
          },
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools-extension-pack"
            ],
            "settings": {
                "cmake.configureOnOpen": true,
                "cmake.buildDirectory": "${workspaceFolder}/build",
                "cmake.sourceDirectory": "${workspaceFolder}/src"
            }
        }
    },
    "remoteUser": "root",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/wondertrader,type=bind,consistency=cached",
    "workspaceFolder": "/workspaces/wondertrader",
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined"
    ],
    "postCreateCommand": "cmake -B build -S src"
} 
